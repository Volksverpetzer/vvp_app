{
  "name": "vvp_app",
  "version": "2.1.11",
  "versionCode": 2605081,
  "main": "expo-router/entry",
  "expo": {
    "install": {
      "exclude": [
        "@stripe/stripe-react-native",
        "@react-navigation/bottom-tabs",
        "react",
        "react-dom",
        "react-native-svg",
        "react-native-webview",
        "react-native-worklets"
      ]
    }
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": "24.x"
  },
  "license": "MIT",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild --clean",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "android:local": "pnpx eas-cli build -p android --profile local-apk --local",
    "android:submit": "pnpx eas-cli build -p android --auto-submit",
    "dev:android": "pnpx eas-cli build -p android --profile development",
    "dev:ios": "pnpx eas-cli build -p ios --profile development",
    "dev:all": "pnpx eas-cli build -p all --profile development",
    "ios": "expo run:ios",
    "ios:local": "pnpx eas-cli build -p ios --profile local-ios --local",
    "preview:build": "pnpx eas-cli build -p android --profile preview",
    "preview:update": "pnpx eas-cli update --channel preview --auto",
    "web": "expo start --web",
    "--- check test and lint ---": "-------------",
    "check": "pnpm check:spelling && pnpm check:ts",
    "check:spelling": "cspell lint",
    "check:ts": "tsc --noEmit",
    "test": "jest --detectOpenHandles",
    "lint": "expo lint .",
    "lint:fix": "expo lint . --fix",
    "------ expo scripts -------": "-------------",
    "expo:check": "expo install --check",
    "expo:doctor": "pnpx expo-doctor",
    "expo:eject": "expo eject",
    "------- npm scripts -------": "-------------",
    "prepare": "husky",
    "prepare:fdroid": "node scripts/prepare-fdroid.mjs",
    "prepare:licenses": "node scripts/generateLicenses.js",
    "watchman:reset": "watchman watch-del \"$PWD\" ; watchman watch-project \"$PWD\""
  },
